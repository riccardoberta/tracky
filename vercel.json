{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "tracky/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/tracky/static/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/tracky/static/img/favicon.svg"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
